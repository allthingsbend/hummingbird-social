---
import Layout from '../layouts/Layout.astro';

const title = 'HTML Sitemap | Hummingbird Social Studio';
const description = 'Browse all pages on Hummingbird Social Studio, including wedding invitation suites, custom design pages, and helpful wedding stationery resources.';
---

<Layout title={title} description={description}>

<section class="hero">
  <div class="container">
    <h1>Site Map</h1>
    <p>
      Browse the main pages and wedding invitation suite collections from Hummingbird Social Studio.
    </p>
  </div>
</section>

<section class="content-section">
  <div class="container">

    <h2>Main Pages</h2>
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/how-it-works/">How It Works</a></li>
      <li><a href="/custom-design-requests/">Custom Design Requests</a></li>
      <li><a href="/printing-guide/">Printing Guide</a></li>
      <li><a href="/wording-etiquette/">Wording & Etiquette</a></li>
      <li><a href="/bridal-shower-invitations/">Bridal Shower Invitations</a></li>
      <li><a href="/faq/">FAQ</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>

    <h2>Wedding Invitation Suites</h2>
    <ul>
      <li><a href="/wedding-invitation-suites/">Wedding Invitation Suites</a></li>
      <li><a href="/wedding-invitation-suites/bend-oregon-wedding-invitations/">Bend Oregon Wedding Invitations</a></li>
      <li><a href="/wedding-invitation-suites/black-and-white-weddings/">Black & White Wedding Invitations</a></li>
      <li><a href="/wedding-invitation-suites/boho-weddings/">Boho Wedding Invitations</a></li>
      <li><a href="/wedding-invitation-suites/mid-century-modern-weddings/">Mid-Century Modern Wedding Invitations</a></li>
      <li><a href="/wedding-invitation-suites/minimalist-weddings/">Minimalist Wedding Invitations</a></li>
      <li><a href="/wedding-invitation-suites/mountain-weddings/">Mountain Wedding Invitations</a></li>
      <li><a href="/wedding-invitation-suites/vintage-weddings/">Vintage Wedding Invitations</a></li>
    </ul>

  </div>
</section>

</Layout>
