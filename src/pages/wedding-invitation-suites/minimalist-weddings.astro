---
import Layout from '../../layouts/Layout.astro';

const title = 'Minimalist Wedding Invitations | Downloadable Wedding Invitation Templates';
const description = 'Shop minimalist wedding invitations from Hummingbird Social Studio. Explore clean, modern, downloadable wedding invitation templates for simple, elegant celebrations.';

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Minimalist Wedding Invitations",
  "description": description,
  "url": "https://hummingbirdsocialstudio.com/wedding-invitation-suites/minimalist-weddings",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Hummingbird Social Studio",
    "url": "https://hummingbirdsocialstudio.com"
  }
};
---

<Layout title={title} description={description}>
  <main class="page">
    <section class="hero">
      <p class="eyebrow">Downloadable Wedding Invitation Templates</p>
      <h1>Minimalist Wedding Invitations</h1>
      <p class="intro">
        Clean, modern, and timeless wedding invitation templates made for couples who love simple design, soft details, and an easy digital download experience.
      </p>
      <a class="button" href="/wedding-invitation-suites">Browse Wedding Invitation Suites</a>
    </section>

    <section class="content-section">
      <h2>Simple Wedding Invitations With a Modern Look</h2>
      <p>
        Our minimalist wedding invitations are designed for couples who want wedding stationery that feels refined without feeling overdone. These downloadable templates focus on clean typography, balanced spacing, and elegant layouts that let your wedding details shine.
      </p>
      <p>
        Each design is created to be easy to personalize, download, and print. Whether you are planning an intimate ceremony, a modern city wedding, or a relaxed outdoor celebration, minimalist invitations offer a polished look that works with almost any wedding style.
      </p>
    </section>

    <section class="content-section">
      <h2>What Makes These Invitations Different?</h2>
      <div class="grid">
        <div>
          <h3>Instant Download</h3>
          <p>Access your wedding invitation template without waiting for a custom design timeline.</p>
        </div>
        <div>
          <h3>Editable Design</h3>
          <p>Update your names, date, location, RSVP details, and wording to fit your celebration.</p>
        </div>
        <div>
          <h3>Clean Typography</h3>
          <p>Minimalist fonts and thoughtful spacing create a calm, elevated look.</p>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2>Perfect For These Wedding Styles</h2>
      <ul>
        <li>Modern weddings</li>
        <li>Intimate weddings</li>
        <li>Courthouse weddings</li>
        <li>Garden weddings</li>
        <li>Destination weddings</li>
        <li>Elegant black-tie celebrations</li>
      </ul>
    </section>

    <section class="content-section">
      <h2>Minimalist Wedding Invitation FAQs</h2>

      <h3>Are these minimalist wedding invitations downloadable?</h3>
      <p>Yes. These invitations are designed as downloadable wedding invitation templates that you can customize and print on your own.</p>

      <h3>Can I use these for a full wedding invitation suite?</h3>
      <p>Yes. Minimalist invitation designs pair well with matching RSVP cards, details cards, save the dates, and wedding weekend stationery.</p>

      <h3>Are minimalist wedding invitations good for formal weddings?</h3>
      <p>Yes. Minimalist wedding invitations can feel very elegant when paired with strong typography, neutral colors, and thoughtful spacing.</p>
    </section>

    <section class="cta">
      <h2>Find a Minimalist Wedding Invitation Style You Love</h2>
      <p>Explore downloadable wedding invitation suites designed to feel simple, polished, and personal.</p>
      <a class="button" href="/wedding-invitation-suites">View Wedding Invitation Suites</a>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
