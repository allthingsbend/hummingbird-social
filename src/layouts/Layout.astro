---
import '../styles/global.css';
import '../styles/hss-phase1.css';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link
      rel="icon"
      type="image/png"
      href="/images/hummingbird-social-studio-favicon.png"
    />
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">
        <img
          src="/images/hummingbird-social-studio-logo.png"
          alt="Hummingbird Social Studio"
        />
      </a>

      <button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
        Menu
      </button>

      <nav class="nav" aria-label="Main navigation">
        <a href="/wedding-invitation-suites/">Wedding Invitations</a>
        <a href="/bridal-shower-invitations/">Bridal Shower</a>
        <a href="/how-it-works/">How It Works</a>
        <a href="/printing-guide/">Printing Guide</a>
        <a href="/faq/">FAQ</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <p>
        Hummingbird Social Studio creates downloadable wedding invitation
        templates, bridal shower invitations, and modern celebration
        stationery.
      </p>

      <p>
        <a href="/how-it-works/">How It Works</a> ·
        <a href="/printing-guide/">Printing Guide</a> ·
        <a href="/wording-etiquette/">Wording & Etiquette</a> ·
        <a href="/faq/">FAQ</a> ·
        <a href="/custom-design-requests/">Custom Design Requests</a> ·
        <a href="/sitemap/">Sitemap</a>
      </p>

      <p>© 2026 Hummingbird Social Studio</p>
    </footer>

    <script>
      const menuButton = document.querySelector('.menu-toggle');
      const nav = document.querySelector('.nav');

      menuButton?.addEventListener('click', () => {
        const isOpen = nav?.classList.toggle('is-open');
        menuButton.setAttribute('aria-expanded', String(isOpen));
      });
    </script>
  </body>
</html>
