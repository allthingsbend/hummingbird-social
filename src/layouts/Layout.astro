---
import '../styles/global.css';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>

    <meta name="description" content={description} />

    <link
      rel="icon"
      type="image/png"
      href="/images/hummingbird-social-studio-favicon.png"
    />
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">
        <img
          src="/images/hummingbird-social-studio-logo.png"
          alt="Hummingbird Social Studio"
        />
      </a>

      <nav class="nav">
        <a href="/wedding-invitation-suites/">Wedding Invitations</a>
        <a href="/bridal-shower-invitations/">Bridal Shower</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <p>
        Hummingbird Social Studio creates downloadable wedding invitation
        templates, bridal shower invitations, and modern celebration
        stationery.
      </p>

      <p>© 2026 Hummingbird Social Studio</p>
    </footer>
  </body>
</html>
